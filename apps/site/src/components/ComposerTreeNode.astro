---
import { withBasePath } from "@/lib/site-base";

interface TreeWork {
  id: string;
  title: string;
  href: string;
}

interface TreeNode {
  id: string;
  title: string;
  href: string;
  children: TreeNode[];
  works: TreeWork[];
}

interface Props {
  node: TreeNode;
}

const { node } = Astro.props;
---

<section id={node.id} class="tree-node">
  <details open>
    <summary>
      <a href={withBasePath(node.href)}>{node.title}</a>
    </summary>

    {node.children.length > 0 && (
      <div class="tree-node__children">
        {node.children.map((child) => (
          <Astro.self node={child} />
        ))}
      </div>
    )}

    {node.works.length > 0 && (
      <ul class="tree-node__works">
        {node.works.map((work) => (
          <li><a href={withBasePath(work.href)}>{work.title}</a></li>
        ))}
      </ul>
    )}
  </details>
</section>
