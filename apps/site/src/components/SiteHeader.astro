---
import { withBasePath } from "@/lib/site-base";

const navItems = [
  { href: withBasePath("/"), label: "首页" },
  { href: withBasePath("/composers/"), label: "作曲家" },
  { href: withBasePath("/conductors/"), label: "指挥" },
  { href: withBasePath("/search/"), label: "搜索" },
  { href: withBasePath("/about/"), label: "关于" },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__spacer" aria-hidden="true"></div>

    <nav class="site-nav" aria-label="主导航">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="site-search-shell" data-site-search>
      <button class="site-search__toggle" type="button" aria-label="打开搜索" aria-expanded="false">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.5 4.5a6 6 0 1 0 0 12a6 6 0 0 0 0-12Zm0-1.5a7.5 7.5 0 1 1 0 15a7.5 7.5 0 0 1 0-15Zm6.1 12.54l4.43 4.42l-1.06 1.06l-4.42-4.43z"></path>
        </svg>
      </button>
      <form action={withBasePath("/search/")} class="site-search" role="search">
        <label class="sr-only" for="global-search">搜索</label>
        <input id="global-search" name="q" type="search" placeholder="搜索作曲家、指挥、乐团、类型、作品" />
      </form>
    </div>
  </div>
</header>

<script is:inline>
  const searchShell = document.querySelector("[data-site-search]");
  const toggle = searchShell?.querySelector(".site-search__toggle");
  const input = searchShell?.querySelector("input");

  toggle?.addEventListener("click", () => {
    const nextState = !searchShell.classList.contains("is-open");
    searchShell.classList.toggle("is-open", nextState);
    toggle.setAttribute("aria-expanded", nextState ? "true" : "false");
    if (nextState && input instanceof HTMLInputElement) {
      input.focus();
    }
  });

  input?.addEventListener("blur", () => {
    if (input instanceof HTMLInputElement && !input.value.trim()) {
      searchShell?.classList.remove("is-open");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
